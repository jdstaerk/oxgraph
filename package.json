{
  "name": "oxgraph",
  "private": true,
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "clean": "shx rm -rf packages/core/target packages/core/*.node packages/ui/dist packages/cli/public-ui packages/cli/dist",
    "lint": "oxlint",
    "format": "oxc format",
    "build:core": "pnpm --filter @oxgraph/core run build",
    "build:ui": "pnpm --filter @oxgraph/ui run build",
    "copy:ui": "shx rm -rf packages/cli/public-ui && shx cp -r packages/ui/dist packages/cli/public-ui",
    "build:cli": "pnpm --filter @oxgraph/cli run build",
    "build": "pnpm run build:core && pnpm run build:ui && pnpm run copy:ui && pnpm run build:cli",
    "dev": "pnpm run oxgraph:build -- --file .",
    "dev:api": "pnpm --filter @oxgraph/cli run dev:api --",
    "dev:ui": "pnpm --filter @oxgraph/ui run dev",
    "oxgraph": "node packages/cli/dist/bin/oxgraph.js",
    "oxgraph:build": "pnpm run build && node packages/cli/dist/bin/oxgraph.js"
  },
  "keywords": [],
  "author": "",
  "license": "GNU GPLv3 ",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "oxlint": "latest",
    "shx": "^0.4.0"
  }
}

{
  "name": "@oxgraph/core",
  "version": "0.1.0",
  "description": "High-performance AST parser for oxgraph",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "binaryName": "oxgraph-core",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "dev": "napi build --platform",
    "test": "cargo test",
    "lint": "oxlint . && cargo clippy",
    "format:fix": "oxlint . --fix",
    "format:check": "oxlint ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.5.3",
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0"
  }
}

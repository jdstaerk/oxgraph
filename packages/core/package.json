{
  "name": "@oxgraph/core",
  "version": "0.1.1",
  "description": "Native Rust dependency and call graph engine for oxgraph",
  "homepage": "https://github.com/jdstaerk/oxgraph#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdstaerk/oxgraph.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/jdstaerk/oxgraph/issues"
  },
  "keywords": [
    "code-analysis",
    "call-graph",
    "dependency-graph",
    "typescript",
    "javascript",
    "rust",
    "oxc"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.13"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "README.md",
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "binaryName": "oxgraph-core",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "dev": "napi build --platform",
    "test": "cargo test",
    "lint": "oxlint . && cargo clippy",
    "format:fix": "oxlint . --fix",
    "format:check": "oxlint ."
  },
  "author": "",
  "packageManager": "pnpm@11.5.3",
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0"
  }
}

{
  "name": "@oxgraph/cli",
  "version": "0.1.0",
  "description": "CLI and local UI for Rust-powered JavaScript and TypeScript codebase graphs",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/jdstaerk/oxgraph#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdstaerk/oxgraph.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/jdstaerk/oxgraph/issues"
  },
  "keywords": [
    "code-analysis",
    "call-graph",
    "dependency-graph",
    "typescript",
    "javascript",
    "react-flow",
    "oxc"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "files": [
    "README.md",
    "dist",
    "public-ui"
  ],
  "bin": {
    "oxgraph": "./dist/bin/oxgraph.js"
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -p tsconfig.json && pnpm run copy:ui",
    "copy:ui": "shx rm -rf public-ui && shx cp -r ../ui/dist public-ui",
    "dev": "shx rm -rf dist && tsc -p tsconfig.json && node dist/bin/oxgraph.js ../.. --api-only --no-open",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "format:fix": "oxlint . --fix",
    "format:check": "oxlint ."
  },
  "dependencies": {
    "@oxgraph/core": "workspace:*",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@oxgraph/ui": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "shx": "^0.4.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
